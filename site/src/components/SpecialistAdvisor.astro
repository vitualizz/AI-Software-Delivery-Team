---
import type { UIStrings } from '@i18n/types'

interface Props { t: UIStrings }
const { t } = Astro.props
const s = t.specialists.orchestrator
---
<div class="advisor-wrap v3-reveal">
  <div class="advisor-strip">
    <span>{t.specialists.advisorStrip}</span>
  </div>
  <div class="advisor">
    <div class="advisor-inner">
      <div class="card-icon">
        <svg aria-hidden="true" width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
        </svg>
      </div>
      <div class="card-body">
        <div class="card-header">
          <h3>{s.name}</h3>
          <code class="card-cmd">{s.command}</code>
        </div>
        <p>{s.desc}</p>
      </div>
    </div>
  </div>
</div>

<style>
.advisor-wrap { max-width: 720px; margin: 0 auto 18px; }
.advisor-strip {
  display: flex;
  justify-content: center;
  margin-bottom: 0;
}
.advisor-strip span {
  font-family: var(--font-mono);
  font-size: 11.5px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  border: 1px solid var(--border-soft);
  border-bottom: none;
  border-radius: 10px 10px 0 0;
  padding: 6px 18px 8px;
  background: oklch(0.18 0.012 285 / 0.6);
}
.advisor {
  position: relative;
  border-radius: 18px;
  padding: 1px;
  background: linear-gradient(
    120deg,
    oklch(0.76 0.145 75 / 0.55),
    oklch(0.74 0.145 300 / 0.55),
    oklch(0.74 0.145 245 / 0.55),
    oklch(0.76 0.145 155 / 0.55),
    oklch(0.72 0.145 25 / 0.55),
    oklch(0.75 0.145 340 / 0.55)
  );
}
.advisor-inner {
  border-radius: 17px;
  background: oklch(0.165 0.014 285);
  padding: 26px 28px;
  display: flex;
  gap: 20px;
  align-items: flex-start;
}
.card-icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 11px;
  color: var(--color-accent);
  background: oklch(from var(--color-accent) l c h / 0.12);
  border: 1px solid oklch(from var(--color-accent) l c h / 0.30);
}
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  margin-bottom: 6px;
}
.card-header h3 { font-size: 17.5px; font-weight: 600; }
.card-body p { font-size: 14.5px; color: var(--color-text-muted); line-height: 1.6; }
.card-cmd {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--color-accent);
  border: 1px solid oklch(from var(--color-accent) l c h / 0.35);
  background: oklch(from var(--color-accent) l c h / 0.08);
  border-radius: 999px;
  padding: 3px 11px;
  white-space: nowrap;
}

@media (max-width: 640px) {
  .advisor-inner { flex-direction: column; }
}
</style>
