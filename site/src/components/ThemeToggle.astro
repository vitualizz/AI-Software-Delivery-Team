---
interface Props { label: string }
const { label } = Astro.props
---
<button
  data-theme-toggle
  aria-label={label}
  class="p-2 rounded-md text-(--color-text-muted) hover:text-(--color-text) hover:bg-(--color-surface) transition-colors cursor-pointer"
  title={label}
>
  <span class="theme-icon-dark" aria-hidden="true">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
      <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
  </span>
  <span class="theme-icon-light hidden" aria-hidden="true">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </span>
</button>

<script>
document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((btn) => {
  function updateIcons(btn: HTMLButtonElement) {
    const theme = document.documentElement.getAttribute('data-theme') ?? 'dark'
    const darkIcon = btn.querySelector('.theme-icon-dark') as HTMLElement | null
    const lightIcon = btn.querySelector('.theme-icon-light') as HTMLElement | null
    if (darkIcon) darkIcon.classList.toggle('hidden', theme === 'light')
    if (lightIcon) lightIcon.classList.toggle('hidden', theme === 'dark')
  }

  updateIcons(btn)

  btn.addEventListener('click', () => {
    const html = document.documentElement
    const current = html.getAttribute('data-theme') ?? 'dark'
    const next = current === 'dark' ? 'light' : 'dark'
    html.setAttribute('data-theme', next)
    localStorage.setItem('asdt-theme', next)
    updateIcons(btn)
  })
})
</script>
