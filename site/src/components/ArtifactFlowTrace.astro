---
import { artifactGraph, SPECIALIST_COLOR, SPECIALIST_LABEL } from '@data/artifact-graph'
import type { SpecialistId } from '@data/artifact-graph'
import type { Locale } from '@i18n/utils'

interface Props {
  specialistId: SpecialistId
  lang: Locale
  labelReads: string
  labelWrites: string
}
const { specialistId, labelReads, labelWrites } = Astro.props
const artifacts = artifactGraph[specialistId]

function resolveSourceColor(key: string): string {
  for (const [id, data] of Object.entries(artifactGraph)) {
    if (data.writes.some(w => w.key === key)) {
      return SPECIALIST_COLOR[id as SpecialistId]
    }
  }
  return '--color-accent'
}
---

<div class="aft">
  <div class="aft-region aft-reads">
    <p class="aft-region-label">{labelReads}</p>
    <ul class="aft-list">
      {artifacts.reads.map((ref) => (
        <li>
          {ref.sentinel ? (
            <span class="aft-sentinel">{ref.key}</span>
          ) : (
            <span
              class:list={['aft-badge', { 'aft-badge--optional': ref.optional }]}
              style={`--bc: var(${resolveSourceColor(ref.key)})`}
            >
              {ref.key}
            </span>
          )}
        </li>
      ))}
    </ul>
  </div>

  <div class="aft-center">
    <span class="aft-node" style={`--sc: var(${SPECIALIST_COLOR[specialistId]})`}>
      {SPECIALIST_LABEL[specialistId]}
    </span>
  </div>

  <div class="aft-region aft-writes">
    <p class="aft-region-label">{labelWrites}</p>
    <ul class="aft-list">
      {artifacts.writes.map((ref) => (
        <li>
          <span
            class="aft-badge"
            style={`--bc: var(${SPECIALIST_COLOR[specialistId]})`}
          >
            {ref.key}
          </span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
.aft {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  grid-template-areas: 'reads center writes';
  align-items: center;
  gap: 16px;
  margin: 0 0 32px;
  padding: 20px;
  border: 1px solid var(--border-soft);
  border-radius: 12px;
  background: oklch(from var(--color-accent) l c h / 0.02);
}

.aft-reads  { grid-area: reads; }
.aft-center { grid-area: center; }
.aft-writes { grid-area: writes; }

.aft-region-label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--faint);
  margin: 0 0 8px;
}

.aft-reads .aft-region-label { text-align: right; }
.aft-writes .aft-region-label { text-align: left; }

.aft-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.aft-reads .aft-list { align-items: flex-end; }
.aft-writes .aft-list { align-items: flex-start; }

.aft-badge {
  font-family: var(--font-mono);
  font-size: 11.5px;
  padding: 3px 9px;
  border-radius: 6px;
  border: 1px solid oklch(from var(--bc) l c h / 0.30);
  color: oklch(from var(--bc) l c h / 0.75);
  background: oklch(from var(--bc) l c h / 0.08);
  white-space: nowrap;
  display: inline-block;
}

.aft-badge--optional {
  border-style: dashed;
  opacity: 0.70;
}

.aft-sentinel {
  font-family: var(--font-mono);
  font-size: 11.5px;
  color: var(--faint);
  font-style: italic;
  padding: 3px 0;
  display: inline-block;
}

.aft-node {
  font-family: var(--font-mono);
  font-size: 12.5px;
  color: var(--sc);
  background: oklch(from var(--sc) l c h / 0.12);
  border: 1px solid oklch(from var(--sc) l c h / 0.25);
  padding: 6px 14px;
  border-radius: 8px;
  white-space: nowrap;
  display: block;
  text-align: center;
}

@media (max-width: 899px) {
  .aft {
    grid-template-columns: 1fr;
    grid-template-areas:
      'reads'
      'center'
      'writes';
    text-align: center;
  }
  .aft-reads .aft-region-label,
  .aft-writes .aft-region-label { text-align: center; }
  .aft-reads .aft-list,
  .aft-writes .aft-list { align-items: center; }
}

html[data-theme='light'] .aft {
  background: oklch(from var(--color-accent) l c h / 0.03);
}

html[data-theme='light'] .aft-badge {
  color: oklch(from var(--bc) l c h / 0.65);
  background: oklch(from var(--bc) l c h / 0.10);
  border-color: oklch(from var(--bc) l c h / 0.35);
}
</style>
