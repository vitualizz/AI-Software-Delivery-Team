---
import type { UIStrings } from '@i18n/types'
import { getBaseHref } from '@i18n/utils'

interface Props { t: UIStrings }
const { t } = Astro.props
---
<footer class="mt-auto border-t border-(--color-border) bg-(--color-surface)">
  <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-8 sm:flex-row">
    <p class="text-sm text-(--color-text-muted)">{t.footer.tagline}</p>
    <nav aria-label="Footer navigation" class="flex items-center gap-6 text-sm">
      <a href={getBaseHref('/docs/getting-started')} class="text-(--color-text-muted) hover:text-(--color-text) transition-colors">{t.footer.docsLabel}</a>
      <a href="https://github.com/vitualizz/AI-Software-Delivery-Team" target="_blank" rel="noopener noreferrer" class="text-(--color-text-muted) hover:text-(--color-text) transition-colors">{t.footer.githubLabel}</a>
      <a href="https://github.com/vitualizz/AI-Software-Delivery-Team/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="text-(--color-text-muted) hover:text-(--color-text) transition-colors">{t.footer.licenseLabel}</a>
    </nav>
    <p class="credit">{t.footer.credit}</p>
  </div>
</footer>

<style>
.credit {
  font-size: 11px;
  color: var(--color-text-muted);
  opacity: 0.7;
  text-align: center;
}
</style>
