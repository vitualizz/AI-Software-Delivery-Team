<span class="logo-dots" aria-hidden="true">
  <span></span><span></span><span></span>
  <span></span><span></span><span></span>
</span>

<style>
.logo-dots {
  display: flex;
  gap: 3px;
}
.logo-dots span {
  width: 7px;
  height: 12px;
  border-radius: 2.5px;
}
.logo-dots span:nth-child(1) { background: var(--c-pm); }
.logo-dots span:nth-child(2) { background: var(--c-arch); }
.logo-dots span:nth-child(3) { background: var(--c-dev); }
.logo-dots span:nth-child(4) { background: var(--c-qa); }
.logo-dots span:nth-child(5) { background: var(--c-sec); }
.logo-dots span:nth-child(6) { background: var(--c-ux); }
</style>
