---
import { getLocalePath } from '@i18n/utils'
import type { Locale } from '@i18n/utils'

interface Props { lang: Locale; currentPath: string; label: string }
const { lang, currentPath, label } = Astro.props

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const withoutBase = currentPath.startsWith(base) ? currentPath.slice(base.length) || '/' : currentPath
const canonical = withoutBase.replace(/^\/es(\/|$)/, '/') || '/'
const enPath = getLocalePath(canonical, 'en')
const esPath = getLocalePath(canonical, 'es')
---
<nav aria-label={label} class="flex items-center gap-1 text-xs font-mono">
  <a
    href={enPath}
    onclick="localStorage.setItem('asdt-lang', 'en')"
    aria-current={lang === 'en' ? 'true' : undefined}
    class:list={[
      'px-2 py-1 rounded transition-colors',
      lang === 'en'
        ? 'text-(--color-accent) bg-(--color-surface)'
        : 'text-(--color-text-muted) hover:text-(--color-text)',
    ]}
  >EN</a>
  <span class="text-(--color-border)">|</span>
  <a
    href={esPath}
    onclick="localStorage.setItem('asdt-lang', 'es')"
    aria-current={lang === 'es' ? 'true' : undefined}
    class:list={[
      'px-2 py-1 rounded transition-colors',
      lang === 'es'
        ? 'text-(--color-accent) bg-(--color-surface)'
        : 'text-(--color-text-muted) hover:text-(--color-text)',
    ]}
  >ES</a>
</nav>
