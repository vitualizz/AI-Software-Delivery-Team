---
import type { UIStrings } from '@i18n/types'

interface Props { t: UIStrings }
const { t } = Astro.props
const nodes = t.pipeline.nodes
const R = 36
const GAP = 150
const START_X = 70
const Y = 60
---
<section class="px-6 py-24 border-t border-(--color-border)">
  <div class="mx-auto max-w-7xl space-y-12">
    <div class="text-center space-y-4">
      <h2 class="text-3xl font-bold tracking-tight text-(--color-text)">{t.pipeline.title}</h2>
      <p class="mx-auto max-w-2xl text-(--color-text-muted)">{t.pipeline.sub}</p>
    </div>
    <div class="overflow-x-auto">
      <svg
        viewBox={`0 0 ${START_X * 2 + GAP * (nodes.length - 1)} ${Y * 2 + 52}`}
        role="img"
        aria-labelledby="pipeline-title pipeline-desc"
        class="mx-auto w-full max-w-4xl"
      >
        <title id="pipeline-title">{t.pipeline.a11yTitle}</title>
        <desc id="pipeline-desc">{t.pipeline.a11yDesc}</desc>
        <defs>
          <marker id="arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
            <path d="M0,0 L0,6 L8,3 z" fill="var(--color-muted, #8b949e)" />
          </marker>
        </defs>
        {nodes.map((node, i) => {
          const cx = START_X + i * GAP
          const cy = Y
          return (
            <>
              {i > 0 && (
                <line
                  x1={START_X + (i - 1) * GAP + R + 4}
                  y1={cy}
                  x2={cx - R - 4}
                  y2={cy}
                  stroke="var(--color-border, #30363d)"
                  stroke-width="1.5"
                  marker-end="url(#arrow)"
                  class={`pipe-line pipe-line-${i}`}
                />
              )}
              <circle cx={cx} cy={cy} r={R} fill="var(--color-surface, #161b22)" stroke="var(--color-accent, #3fb950)" stroke-width="1.5" class={`pipe-circle pipe-circle-${i}`} />
              <text
                x={cx}
                y={cy + R + 18}
                text-anchor="middle"
                font-size="11"
                font-family="var(--font-mono, monospace)"
                fill="var(--color-text-muted, #8b949e)"
              >
                {node.label}
              </text>
              <text
                x={cx}
                y={cy + 5}
                text-anchor="middle"
                font-size="10"
                font-family="var(--font-mono, monospace)"
                fill="var(--color-accent, #3fb950)"
                font-weight="600"
              >
                {node.id.toUpperCase().slice(0, 3)}
              </text>
            </>
          )
        })}
      </svg>
    </div>
  </div>
</section>

<style>
  @keyframes draw {
    to { stroke-dashoffset: 0; }
  }

  @keyframes node-glow {
    0%, 100% { stroke-opacity: 0.6; }
    50% { stroke-opacity: 1; }
  }

  @media (prefers-reduced-motion: no-preference) {
    .pipe-circle {
      stroke-dasharray: 226;
      stroke-dashoffset: 226;
    }
    .pipe-line {
      stroke-dasharray: 70;
      stroke-dashoffset: 70;
    }
    .pipe-circle-0 { animation: draw 0.5s ease 0s forwards, node-glow 2s ease-in-out 0.5s infinite; }
    .pipe-circle-1 { animation: draw 0.5s ease 0.6s forwards, node-glow 2s ease-in-out 1.1s infinite; }
    .pipe-circle-2 { animation: draw 0.5s ease 1.2s forwards, node-glow 2s ease-in-out 1.7s infinite; }
    .pipe-circle-3 { animation: draw 0.5s ease 1.8s forwards, node-glow 2s ease-in-out 2.3s infinite; }
    .pipe-circle-4 { animation: draw 0.5s ease 2.4s forwards, node-glow 2s ease-in-out 2.9s infinite; }
    .pipe-circle-5 { animation: draw 0.5s ease 3.0s forwards, node-glow 2s ease-in-out 3.5s infinite; }
    .pipe-line-1 { animation: draw 0.3s ease 0.5s forwards; }
    .pipe-line-2 { animation: draw 0.3s ease 1.1s forwards; }
    .pipe-line-3 { animation: draw 0.3s ease 1.7s forwards; }
    .pipe-line-4 { animation: draw 0.3s ease 2.3s forwards; }
    .pipe-line-5 { animation: draw 0.3s ease 2.9s forwards; }
  }
</style>
