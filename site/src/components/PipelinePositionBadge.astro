---
import { PIPELINE_ORDER, SPECIALIST_COLOR, SPECIALIST_LABEL } from '@data/artifact-graph'
import type { SpecialistId } from '@data/artifact-graph'
import type { Locale } from '@i18n/utils'
import { getBaseHref } from '@i18n/utils'

interface Props {
  specialistId: SpecialistId
  lang: Locale
  label: string
}
const { specialistId, lang, label } = Astro.props
const isEs = lang === 'es'
---

<div class="ppb">
  <p class="ppb-label">{label}</p>
  <div class="ppb-track" role="list">
    {PIPELINE_ORDER.map((id) => {
      const isCurrent = id === specialistId
      const href = isEs
        ? getBaseHref(`/es/docs/specialists/${id}`)
        : getBaseHref(`/docs/specialists/${id}`)
      return (
        <div class="ppb-item" role="listitem">
          {isCurrent ? (
            <span
              class="ppb-node ppb-node--current"
              style={`--sc: var(${SPECIALIST_COLOR[id]})`}
              aria-current="page"
            >
              {SPECIALIST_LABEL[id]}
            </span>
          ) : (
            <a
              href={href}
              class="ppb-node"
              style={`--sc: var(${SPECIALIST_COLOR[id]})`}
            >
              {SPECIALIST_LABEL[id]}
            </a>
          )}
          {id !== 'ux-ui' && <span class="ppb-connector" aria-hidden="true" />}
        </div>
      )
    })}
  </div>
</div>

<style>
.ppb {
  margin: 20px 0 28px;
}

.ppb-label {
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--faint);
  margin: 0 0 10px;
}

.ppb-track {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 4px 0;
}

.ppb-item {
  display: flex;
  align-items: center;
}

.ppb-node {
  font-family: var(--font-mono);
  font-size: 11.5px;
  padding: 3px 10px;
  border-radius: 6px;
  border: 1px solid oklch(from var(--sc) l c h / 0.18);
  color: oklch(from var(--sc) l c h / 0.50);
  background: oklch(from var(--sc) l c h / 0.05);
  white-space: nowrap;
  text-decoration: none;
  transition: color 0.15s, background 0.15s, border-color 0.15s;
}

a.ppb-node:hover {
  color: var(--sc);
  background: oklch(from var(--sc) l c h / 0.10);
  border-color: oklch(from var(--sc) l c h / 0.35);
}

.ppb-node--current {
  color: var(--sc);
  background: oklch(from var(--sc) l c h / 0.12);
  border-color: oklch(from var(--sc) l c h / 0.25);
  cursor: default;
}

.ppb-connector {
  display: block;
  width: 16px;
  height: 1px;
  background: var(--border-soft);
  position: relative;
  flex-shrink: 0;
}

.ppb-connector::after {
  content: '';
  position: absolute;
  right: -1px;
  top: -3px;
  width: 0;
  height: 0;
  border-top: 3.5px solid transparent;
  border-bottom: 3.5px solid transparent;
  border-left: 5px solid var(--border-soft);
}

@media (max-width: 600px) {
  .ppb-connector { display: none; }
  .ppb-track { gap: 6px; flex-wrap: wrap; }
}

html[data-theme='light'] .ppb-node {
  border-color: oklch(from var(--sc) l c h / 0.25);
  color: oklch(from var(--sc) l c h / 0.62);
  background: oklch(from var(--sc) l c h / 0.08);
}

html[data-theme='light'] .ppb-node--current {
  color: var(--sc);
  background: oklch(from var(--sc) l c h / 0.14);
  border-color: oklch(from var(--sc) l c h / 0.35);
}

@media (prefers-reduced-motion: reduce) {
  .ppb-node { transition: none; }
}
</style>
