---
import BaseLayout from '@layouts/BaseLayout.astro'
import Hero from '@components/Hero.astro'
import ChatVsAsdt from '@components/ChatVsAsdt.astro'
import SpecialistsGrid from '@components/SpecialistsGrid.astro'
import RecipesTabs from '@components/RecipesTabs.astro'
import CtaBand from '@components/CtaBand.astro'
import { useTranslations } from '@i18n/utils'

const lang = 'es'
const t = useTranslations(lang)
---
<BaseLayout lang={lang} title={t.hero.headline} description={t.hero.sub}>
  <Hero t={t} lang={lang} />
  <SpecialistsGrid t={t} />
  <RecipesTabs t={t} />
  <ChatVsAsdt t={t} />
  <CtaBand t={t} />
</BaseLayout>
