---
import DocsLayout from '@layouts/DocsLayout.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const esDocs = await getCollection('docs', (entry) => entry.data.locale === 'es')
  const enDocs = await getCollection('docs', (entry) => entry.data.locale === 'en')

  const esSlugs = new Set(esDocs.map((e) => e.id.replace(/^es\//, '')))

  const esRoutes = esDocs.map((entry) => ({
    params: { slug: entry.id.replace(/^es\//, '') },
    props: { entry, isFallback: false },
  }))

  const enFallbacks = enDocs
    .filter((entry) => !esSlugs.has(entry.id.replace(/^en\//, '')))
    .map((entry) => ({
      params: { slug: entry.id.replace(/^en\//, '') },
      props: { entry, isFallback: true },
    }))

  return [...esRoutes, ...enFallbacks]
}

const { entry, isFallback } = Astro.props
const { Content, headings } = await render(entry)
const slug = entry.id.replace(/^(en|es)\//, '')
---
<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  lang="es"
  isFallback={isFallback}
  currentSlug={slug}
  headings={headings}
>
  <Content />
</DocsLayout>
