---
import NavBar from '@components/NavBar.astro'
import Footer from '@components/Footer.astro'
import SkipLink from '@components/SkipLink.astro'
import Atmo from '@components/Atmo.astro'
import { useTranslations, getBaseHref } from '@i18n/utils'
import type { Locale } from '@i18n/utils'
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  lang: Locale
}

const { title = 'ASDT', description = 'AI Software Delivery Team', lang } = Astro.props
const t = useTranslations(lang)
const currentPath = Astro.url.pathname
---
<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={getBaseHref('/favicon.svg')} />
    <link rel="icon" type="image/x-icon" href={getBaseHref('/favicon.ico')} />
    <title>{title} | ASDT</title>
    <script is:inline>
      /* eslint-disable no-var */
      ;(function () {
        var stored = localStorage.getItem('asdt-theme')
        var preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        var theme = stored || preferred
        document.documentElement.setAttribute('data-theme', theme)
      })()
      /* eslint-enable no-var */
    </script>
    <script is:inline data-base={import.meta.env.BASE_URL.replace(/\/$/, '')}>
      /* eslint-disable no-var */
      (function () {
        var pref = localStorage.getItem('asdt-lang')
        if (pref) return

        var base = document.currentScript.getAttribute('data-base')
        var path = window.location.pathname
        if (path.startsWith(base + '/es') || path === base + '/es') return

        var lang = navigator.language || navigator.userLanguage || ''
        if (!lang.startsWith('es')) return

        localStorage.setItem('asdt-lang', 'es')
        var rest = path.startsWith(base) ? path.slice(base.length) : path
        window.location.replace(base + '/es' + (rest === '/' ? '' : rest))
      })()
      /* eslint-enable no-var */
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-(--color-bg) text-(--color-text)">
    <Atmo />
    <SkipLink label={t.a11y.skipToContent} />
    <NavBar lang={lang} t={t} currentPath={currentPath} />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer t={t} />
  </body>
</html>
